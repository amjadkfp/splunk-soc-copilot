<?xml version="1.0" encoding="UTF-8"?>
<!--
  SOC Copilot — Splunk Simple XML Dashboard
  ==========================================
  File:    splunk/dashboard.xml
  Install: Splunk Web → Search → Dashboards → Create New Dashboard
           (choose "Source" tab, paste this XML)
           — or —
           Place at: $SPLUNK_HOME/etc/apps/<your_app>/lookups/../views/soc_copilot.xml

  All panels query:
      index=soc_copilot  sourcetype=soc_copilot

  Threat-hunt findings are in:
      index=soc_copilot  sourcetype=soc_copilot_threat

  HEC field reference (top-level, no spath needed):
      event_id, event_name, severity, splunk_severity, mitre_technique_id,
      mitre_tactic, EventID, TimeCreated, TargetUserName, SubjectUserName,
      IpAddress, WorkstationName, ComputerName, summary, threat_assessment
-->
<dashboard version="1.1" theme="dark">

  <label>SOC Copilot Security Dashboard</label>
  <description>Real-time Windows Security Event monitoring powered by SOC Copilot + MITRE ATT&amp;CK enrichment</description>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Row 1 — High-level overview: severity distribution + MITRE coverage
       ═══════════════════════════════════════════════════════════════════════ -->
  <row>

    <!-- Panel A: Event count by severity level — pie chart -->
    <panel>
      <title>Events by Severity Level</title>
      <chart>
        <search>
          <query>
            index=soc_copilot sourcetype=soc_copilot
            | stats count by severity
            | sort -count
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>

        <option name="charting.chart">pie</option>
        <option name="charting.chart.showPercent">true</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.drilldown">all</option>

        <!-- Colour-map matches SOC Copilot severity levels -->
        <option name="charting.fieldColors">
          {"Critical":"#D41F1F","High":"#E07F0E","Medium":"#E8C72A","Low":"#65A637","Informational":"#5379AF"}
        </option>
      </chart>
    </panel>

    <!-- Panel B: MITRE ATT&CK technique frequency — bar chart -->
    <panel>
      <title>MITRE ATT&amp;CK Technique Frequency</title>
      <chart>
        <search>
          <query>
            index=soc_copilot sourcetype=soc_copilot mitre_technique_id!="N/A"
            | eval technique = mitre_technique_id . " — " . mitre_technique_name
            | stats count by technique
            | sort -count
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>

        <option name="charting.chart">bar</option>
        <option name="charting.axisTitleY.text">Event Count</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.chart.showDataLabels">all</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.placement">none</option>
      </chart>
    </panel>

  </row>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Row 2 — Critical & High events table (analyst triage view)
       ═══════════════════════════════════════════════════════════════════════ -->
  <row>

    <!-- Panel C: Table of Critical + High events -->
    <panel>
      <title>Critical &amp; High Severity Events — Triage Queue</title>
      <table>
        <search>
          <query>
            index=soc_copilot sourcetype=soc_copilot severity IN ("Critical", "High")
            | eval user = coalesce(TargetUserName, SubjectUserName, "—")
            | eval source_ip = coalesce(IpAddress, "—")
            | table TimeCreated, EventID, user, source_ip, severity, splunk_severity, mitre_technique_id
            | rename
                TimeCreated       AS "Time"
                EventID           AS "Event ID"
                user              AS "User"
                source_ip         AS "Source IP"
                severity          AS "Severity"
                splunk_severity   AS "Score"
                mitre_technique_id AS "MITRE Technique"
            | sort -Score
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>

        <option name="count">25</option>
        <option name="rowNumbers">true</option>
        <option name="wrap">false</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">row</option>

        <!-- Colour-code the Severity column -->
        <format type="color" field="Severity">
          <colorPalette type="map">
            {"Critical":"#D41F1F","High":"#E07F0E","Medium":"#E8C72A","Low":"#65A637","Informational":"#5379AF"}
          </colorPalette>
        </format>

        <!-- Numeric colour scale for Score column (0 → green, 100 → red) -->
        <format type="color" field="Score">
          <colorPalette type="minMidMax" maxColor="#D41F1F" midColor="#E8C72A" minColor="#65A637"/>
          <scale type="minMidMax" minValue="0" midValue="50" maxValue="100"/>
        </format>
      </table>
    </panel>

  </row>

  <!-- ═══════════════════════════════════════════════════════════════════════
       Row 3 — Event timeline (events over time, broken out by severity)
       ═══════════════════════════════════════════════════════════════════════ -->
  <row>

    <!-- Panel D: Timeline of events over time -->
    <panel>
      <title>Event Timeline — Volume by Severity</title>
      <chart>
        <search>
          <query>
            index=soc_copilot sourcetype=soc_copilot
            | timechart span=30m count by severity useother=false
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>

        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.axisTitleY.text">Events per 30 min</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.drilldown">all</option>

        <!-- Match severity colours used in the pie chart -->
        <option name="charting.fieldColors">
          {"Critical":"#D41F1F","High":"#E07F0E","Medium":"#E8C72A","Low":"#65A637","Informational":"#5379AF"}
        </option>
      </chart>
    </panel>

  </row>

</dashboard>
